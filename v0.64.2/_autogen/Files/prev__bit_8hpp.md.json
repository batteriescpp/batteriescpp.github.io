  "programlisting": "//######=###=##=#=#=#=#=#==#==#====#+==#+==============+==+==+==+=+==+=+=+=+=+=+=+\n// Copyright 2025 Anthony Paul Astolfi\n//\n#pragma once\n#define BATTERIES_BIT_OPS_NEXT_BIT_HPP\n\n#include <batteries/config.hpp>\n//\n#include <batteries/bit_ops/last_bit.hpp>\n\nnamespace batt {\n\nconstexpr inline i32 prev_bit(u64 bit_set, i32 index)\n{\n    const u64 mask = ((u64{1} << index) - 1);\n    return last_bit(bit_set & mask);\n}\n\n}  //namespace batt",
