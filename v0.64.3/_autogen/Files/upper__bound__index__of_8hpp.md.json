  "programlisting": "//######=###=##=#=#=#=#=#==#==#====#+==#+==============+==+==+==+=+==+=+=+=+=+=+=+\n// Copyright 2026 Anthony Paul Astolfi\n//\n#pragma once\n#define BATTERIES_BIT_OPS_UPPER_BOUND_INDEX_OF_HPP\n\n#include <batteries/config.hpp>\n//\n#include <batteries/int_types.hpp>\n\n#include <hwy/highway.h>\n\n#include <array>\n#include <type_traits>\n\nnamespace batt {\n\ntemplate <typename T, usize kSize>\ninline i32 upper_bound_index_of(T item, const std::array<T, kSize>& vec)\n{\n    namespace hn = hwy::HWY_NAMESPACE;\n    using D = hn::CappedTag<T, kSize>;\n    D tag;\n\n    static_assert(kSize % hn::Lanes(tag) == 0);\n\n    for (usize i = 0; i < kSize; i += hn::Lanes(tag)) {\n        const hn::Vec<D> pattern = hn::Set(tag, item);\n        const hn::Vec<D> items = hn::LoadU(tag, vec.data() + i);\n        const hn::Mask<D> mask = hn::Lt(pattern, items);\n\n        const i32 first = hn::FindFirstTrue(tag, mask);\n        if (first != -1) {\n            return first + i;\n        }\n    }\n\n    return kSize;\n}\n\ntemplate <typename T, usize kSize>\ninline i32 slow_upper_bound_index_of(T item, const std::array<T, kSize>& vec)\n{\n    i32 result = 0;\n\n    for (T v : vec) {\n        if (v <= item) {\n            ++result;\n            continue;\n        }\n        return result;\n    }\n\n    return kSize;\n}\n\n}  // namespace batt",
