  "programlisting": "//######=###=##=#=#=#=#=#==#==#====#+==#+==============+==+==+==+=+==+=+=+=+=+=+=+\n// Copyright 2025 Anthony Paul Astolfi\n//\n#pragma once\n#define BATTERIES_BIT_OPS_FIRST_BIT_HPP\n\n#include <batteries/config.hpp>\n//\n#include <batteries/bit_ops/bit_count.hpp>\n#include <batteries/int_types.hpp>\n\n#include <array>\n\nnamespace batt {\n\nconstexpr inline i32 first_bit(u64 bit_set)\n{\n    if (bit_set == 0) {\n        return 64;\n    }\n    return trailing_zero_bits(bit_set);\n}\n\ntemplate <usize N>\ninline i32 first_bit(const std::array<u64, N>& bit_set)\n{\n    i32 offset = 0;\n    for (u64 part : bit_set) {\n        if (part != 0) {\n            offset += trailing_zero_bits(part);\n            break;\n        }\n        offset += 64;\n    }\n    return offset;\n}\n\n}  //namespace batt",
