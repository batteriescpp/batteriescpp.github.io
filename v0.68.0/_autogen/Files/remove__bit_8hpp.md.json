  "programlisting": "//######=###=##=#=#=#=#=#==#==#====#+==#+==============+==+==+==+=+==+=+=+=+=+=+=+\n// Copyright 2026 Anthony Paul Astolfi\n//\n#pragma once\n#define BATTERIES_BIT_OPS_REMOVE_BIT_HPP\n\n#include <batteries/config.hpp>\n//\n#include <batteries/int_types.hpp>\n\nnamespace batt {\n\n[[nodiscard]] constexpr inline u64 remove_bit(u64 bit_set, i32 index)\n{\n    const u64 lower_mask = (u64{1} << index) - 1;\n    const u64 upper_mask = (~lower_mask) << 1;\n\n    return (bit_set & lower_mask) | ((bit_set & upper_mask) >> 1);\n}\n\ntemplate <usize N>\n[[nodiscard]] constexpr inline std::array<u64, N> remove_bit(std::array<u64, N> bit_set, i32 index)\n{\n    const i32 word_i = index / 64;\n    const i32 bit_i = index % 64;\n\n    u64 carry = 0;\n\n    for (i32 i = N - 1; i > word_i; --i) {\n        const u64 next_carry = (bit_set[i] & 1) << 63;\n        bit_set[i] = remove_bit(bit_set[i], 0) | carry;\n        carry = next_carry;\n    }\n\n    bit_set[word_i] = remove_bit(bit_set[word_i], bit_i) | carry;\n\n    return bit_set;\n}\n\n}  // namespace batt",
