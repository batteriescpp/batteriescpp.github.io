  "programlisting": "//######=###=##=#=#=#=#=#==#==#====#+==#+==============+==+==+==+=+==+=+=+=+=+=+=+\n// Copyright 2025 Anthony Paul Astolfi\n//\n#pragma once\n#define BATTERIES_BIT_OPS_LAST_BIT_HPP\n\n#include <batteries/config.hpp>\n//\n#include <batteries/bit_ops/bit_count.hpp>\n#include <batteries/int_types.hpp>\n\n#include <array>\n\nnamespace batt {\n\nconstexpr inline i32 last_bit(u64 bit_set)\n{\n    if (bit_set == 0) {\n        return -1;\n    }\n    return 63 - leading_zero_bits(bit_set);\n}\n\ntemplate <usize N>\ninline i32 last_bit(const std::array<u64, N>& bit_set)\n{\n    for (usize i = N; i > 0;) {\n        --i;\n        u64 part = bit_set[i];\n        if (part != 0) {\n            return i * 64 + last_bit(part);\n        }\n    }\n    return -1;\n}\n\n}  //namespace batt",
