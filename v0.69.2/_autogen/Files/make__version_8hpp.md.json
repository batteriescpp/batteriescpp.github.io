  "programlisting": "//######=###=##=#=#=#=#=#==#==#====#+==#+==============+==+==+==+=+==+=+=+=+=+=+=+\n// Copyright 2026 Anthony Paul Astolfi\n//\n#pragma once\n#define BATTERIES_MAKE_VERSION_HPP\n\nnamespace batt {\n\nstatic_assert(sizeof(int) >= 4,\n              \"int must be large enough to hold 3 digits for each of major.minor.patch version parts\");\n\n#define BATT_MAKE_VERSION(major_x, minor_y, patch_z) ((major_x) * 1000000ul + (minor_y) * 1000ul + (patch_z))\n\n}  // namespace batt",
