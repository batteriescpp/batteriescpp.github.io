  "programlisting": "//######=###=##=#=#=#=#=#==#==#====#+==#+==============+==+==+==+=+==+=+=+=+=+=+=+\n// Copyright 2026 Anthony Paul Astolfi\n//\n#pragma once\n#define BATTERIES_BIT_OPS_INDEX_OF_HPP\n\n#include <batteries/config.hpp>\n//\n\n#include <batteries/int_types.hpp>\n#include <batteries/utility.hpp>\n\n#include <hwy/highway.h>\n\nnamespace batt {\n\ntemplate <typename T, usize kSize>\ninline usize slow_index_of(T key_byte, const std::array<T, kSize>& keys)\n{\n    for (usize i = 0; i < keys.size(); ++i) {\n        if (keys[i] == key_byte) {\n            return i;\n        }\n    }\n    return kSize;\n}\n\ntemplate <typename T, usize kSize>\nBATT_ALWAYS_INLINE inline usize index_of(T search_item, const std::array<T, kSize>& items)\n{\n    namespace hn = hwy::HWY_NAMESPACE;\n    using D = hn::CappedTag<T, kSize>;\n    D tag;\n\n    const hn::Vec<D> pattern = hn::Set(tag, search_item);\n\n    for (usize i = 0; i < kSize; i += hn::Lanes(tag)) {\n        const hn::Vec<D> vec = hn::LoadU(tag, items.data() + i);\n        const hn::Mask<D> mask = hn::Eq(pattern, vec);\n\n        auto first = FindFirstTrue(tag, mask);\n        if (first != -1) {\n            return first + i;\n        }\n    }\n\n    return kSize;\n}\n\n}  //namespace batt",
