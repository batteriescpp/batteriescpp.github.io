  "programlisting": "//######=###=##=#=#=#=#=#==#==#====#+==#+==============+==+==+==+=+==+=+=+=+=+=+=+\n// Copyright 2026 Anthony Paul Astolfi\n//\n#pragma once\n#define BATTERIES_BIT_OPS_SET_BIT_HPP\n\n#include <batteries/config.hpp>\n//\n#include <batteries/int_types.hpp>\n\n#include <array>\n\nnamespace batt {\n\n[[nodiscard]] constexpr inline u64 set_bit(u64 bit_set, i32 index, bool value)\n{\n    const u64 mask = u64{1} << index;\n    if (value) {\n        return bit_set | mask;\n    } else {\n        return bit_set & ~mask;\n    }\n}\n\ntemplate <usize N>\n[[nodiscard]] inline std::array<u64, N> set_bit(std::array<u64, N> bit_set, i32 index, bool value)\n{\n    const i32 word_i = index / 64;\n    const i32 bit_i = index % 64;\n    const u64 mask = u64{1} << bit_i;\n\n    if (value) {\n        bit_set[word_i] |= mask;\n    } else {\n        bit_set[word_i] &= ~mask;\n    }\n\n    return bit_set;\n}\n\n}  //namespace batt",
