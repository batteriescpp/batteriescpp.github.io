  "programlisting": "//######=###=##=#=#=#=#=#==#==#====#+==#+==============+==+==+==+=+==+=+=+=+=+=+=+\n// Copyright 2026 Anthony Paul Astolfi\n//\n#pragma once\n#define BATTERIES_BIT_OPS_SUPPORTED_HPP\n\n#include <batteries/config.hpp>\n//\n\n#include <batteries/int_types.hpp>\n#include <batteries/operators.hpp>\n\nnamespace batt {\n\nstruct DumpBitOpsSupported {\n    u32 mmx : 1;\n    u32 sse2 : 1;\n    u32 sse3 : 1;\n    u32 avx : 1;\n    u32 avx512f : 1;\n\n    //+++++++++++-+-+--+----- --- -- -  -  -   -\n\n    DumpBitOpsSupported() noexcept\n    {\n#ifdef __MMX__\n        this->mmx = 1;\n#else\n        this->mmx = 0;\n#endif\n#ifdef __SSE2__\n        this->sse2 = 1;\n#else\n        this->sse2 = 0;\n#endif\n#ifdef __SSE3__\n        this->sse3 = 1;\n#else\n        this->sse3 = 0;\n#endif\n#ifdef __AVX__\n        this->avx = 1;\n#else\n        this->avx = 0;\n#endif\n#ifdef __AVX512F__\n        this->avx512f = 1;\n#else\n        this->avx512f = 0;\n#endif\n    }\n};\n\nBATT_OBJECT_PRINT_IMPL((inline), DumpBitOpsSupported, (mmx, sse2, sse3, avx, avx512f))\n\n}  // namespace batt",
