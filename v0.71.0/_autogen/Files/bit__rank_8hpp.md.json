  "programlisting": "//######=###=##=#=#=#=#=#==#==#====#+==#+==============+==+==+==+=+==+=+=+=+=+=+=+\n// Copyright 2026 Anthony Paul Astolfi\n//\n#pragma once\n#define BATTERIES_BIT_OPS_BIT_RANK_HPP\n\n#include <batteries/bit_ops/bit_count.hpp>\n#include <batteries/int_types.hpp>\n\n#ifdef __BMI2__\n#include <x86gprintrin.h>\n#endif  // __BMI2__\n\n#ifdef __MMX__\n#include <mmintrin.h>\n#endif  // __MMX__\n\n#ifdef __SSE2__\n#include <emmintrin.h>\n#endif  // __SSE2__\n\n#ifdef __SSE3__\n#include <pmmintrin.h>\n#endif  // __SSE3__\n\n#ifdef __AVX__\n#include <immintrin.h>\n#endif\n\n#ifdef __AVX512F__\n#include <immintrin.h>  // AVX512 (AVX, AVX2, FMA)\n#endif\n\nnamespace batt {\n\nconstexpr inline i32 bit_rank(u64 bit_set, i32 index)\n{\n    if (index > 63) {\n        index = 63;\n    }\n    return bit_count(bit_set & ((u64{2} << index) - 1)) - 1;\n}\n\ntemplate <usize N>\nconstexpr inline i32 bit_rank(const std::array<u64, N>& bit_set, i32 index)\n{\n    if (index > N * 64 - 1) {\n        index = N * 64 - 1;\n    }\n\n    const i32 word_i = index / 64;\n    const i32 bit_i = index % 64;\n\n    i32 rank = 0;\n    for (i32 i = 0; i < word_i; ++i) {\n        rank += bit_count(bit_set[i]);\n    }\n    rank += bit_rank(bit_set[word_i], bit_i);\n\n    return rank;\n}\n\n}  // namespace batt",
