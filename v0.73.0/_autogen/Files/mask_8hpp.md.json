  "programlisting": "//######=###=##=#=#=#=#=#==#==#====#+==#+==============+==+==+==+=+==+=+=+=+=+=+=+\n// Copyright 2026 Anthony Paul Astolfi\n//\n#pragma once\n#define BATTERIES_BIT_OPS_MASK_HPP\n\n#include <batteries/int_types.hpp>\n#include <batteries/interval.hpp>\n#include <batteries/utility.hpp>\n\nnamespace batt {\n\nnamespace detail {\n\ntemplate <typename IntervalT>\nBATT_ALWAYS_INLINE inline u64 mask_from_interval_impl(const IntervalT& i)\n{\n    if (i.lower_bound > 63) {\n        return 0;\n    }\n    const auto n = i.size();\n    u64 mask = (n > 63) ? ~u64{0} : ((u64{1} << n) - 1);\n    return mask << i.lower_bound;\n}\n\n}  //namespace detail\n\ntemplate <typename IntT>\ninline u64 mask_from_interval(const CInterval<IntT>& i)\n{\n    return detail::mask_from_interval_impl(i);\n}\n\ntemplate <typename IntT>\ninline u64 mask_from_interval(const Interval<IntT>& i)\n{\n    return detail::mask_from_interval_impl(i);\n}\n\n}  //namespace batt",
